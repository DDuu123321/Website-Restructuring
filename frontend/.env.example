# ─── Site URL (used for sitemap, OG tags, canonical URLs) ──
# In dev: http://localhost:3000
# In prod: https://bluven.com.au
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── CMS URL ──────────────────────────────────────────────
# Server-side fetches go directly here.
# Client-side fetches go through /api proxy in dev, NEXT_PUBLIC_CMS_URL in prod.
CMS_URL=http://localhost:3001
NEXT_PUBLIC_CMS_URL=http://localhost:3001
