# ─── Server ───────────────────────────────────────────────
SERVER_URL=http://localhost:3001
PORT=3001
NODE_ENV=development

# ─── Payload ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=replace_with_64_char_random_string

# ─── Database — PostgreSQL ────────────────────────────────
# Local Postgres:
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/bluven
#
# Railway / Neon / Supabase (managed):
#   DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bluven

# ─── Email — Zoho SMTP ────────────────────────────────────
# Use an App Password generated in Zoho (Mail → Settings → Security
# → App Passwords). The account login password will NOT work for SMTP.
#
# SMTP_HOST: smtp.zoho.com (worldwide) or smtp.zoho.com.au (AU region)
# SMTP_PORT: 465 (SSL — recommended) or 587 (STARTTLS)
SMTP_HOST=smtp.zoho.com.au
SMTP_PORT=465
SMTP_USER=system@yourdomain.com
SMTP_PASS=your_zoho_app_password

EMAIL_FROM=system@yourdomain.com
NOTIFY_EMAIL=system@yourdomain.com

# ─── AI Chat proxy ───────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Public site URL (for sitemap.xml, OG tags, etc) ──────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
