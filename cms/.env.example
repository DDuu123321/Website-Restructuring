# ─── Server ───────────────────────────────────────────────
SERVER_URL=http://localhost:3001
PORT=3001
NODE_ENV=development

# ─── Payload ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=replace_with_64_char_random_string

# ─── Database — PostgreSQL ────────────────────────────────
# Local Postgres:
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/bluven
#
# Railway / Neon / Supabase (managed):
#   DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bluven

# ─── Email (Resend — free tier at resend.com) ─────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@bluven.com.au
NOTIFY_EMAIL=info@bluven.com.au

# ─── AI Chat proxy ───────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Public site URL (for sitemap.xml, OG tags, etc) ──────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
